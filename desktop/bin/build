#!/usr/bin/env bash
#
# Build the packaged app with auto version increment.
#
# Version format: MAJOR.MINOR.PATCH where PATCH auto-increments.
# Version is stored in the root package.json.
#
# Usage: bin/build                        # Mac, no publish
#        bin/build --publish              # Mac + publish to GitHub
#
set -euo pipefail

cd "$(dirname "$0")/.."
ROOT_DIR="$(cd .. && pwd)"

ROOT_PACKAGE_JSON="$ROOT_DIR/package.json"

# ── 0. Parse flags ──────────────────────────────────────────────────
PUBLISH=false

for arg in "$@"; do
  case "$arg" in
    --publish) PUBLISH=true ;;
    *) echo "Unknown flag: $arg (use --publish)"; exit 1 ;;
  esac
done

# ── 1. Pre-flight checks ───────────────────────────────────────────
# Ensure working directory is clean (uncommitted changes can cause confusion)
if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
  echo "Warning: You have uncommitted changes. Build will use the current working tree state."
fi

# Install dependencies
echo "Installing dependencies..."
cd "$ROOT_DIR"
pnpm install
cd desktop

# Workaround: electron-builder looks for 'electron-rebuild' but pnpm uses '@electron/rebuild'
if [ ! -e node_modules/electron-rebuild ]; then
  mkdir -p node_modules
  ln -sf ../../node_modules/.pnpm/@electron+rebuild@4.0.3/node_modules/@electron/rebuild node_modules/electron-rebuild
fi

# ── 2. Version handling ─────────────────────────────────────────────
# Skip bumping if the last commit already matches the current version.
CURRENT_VERSION=$(node -e "console.log(require('$ROOT_PACKAGE_JSON').version)")
HEAD_MSG=$(git log -1 --format='%s' 2>/dev/null || echo "")

if [[ "$HEAD_MSG" == "$CURRENT_VERSION" ]]; then
  echo "Version $CURRENT_VERSION (already committed — skipping bump)"
else
  # Bump patch version (strip 'v' prefix, bump, add back)
  VERSION_NUM="${CURRENT_VERSION#v}"
  IFS='.' read -r MAJOR MINOR PATCH <<< "$VERSION_NUM"
  PATCH=$((PATCH + 1))
  NEW_VERSION="v$MAJOR.$MINOR.$PATCH"

  # Update root package.json and commit the bump
  node -e "
    const fs = require('fs');
    const pkg = JSON.parse(fs.readFileSync('$ROOT_PACKAGE_JSON', 'utf-8'));
    pkg.version = '$NEW_VERSION';
    fs.writeFileSync('$ROOT_PACKAGE_JSON', JSON.stringify(pkg, null, 2) + '\n');
  "
  git add "$ROOT_PACKAGE_JSON"
  git commit -m "$NEW_VERSION" --no-verify

  echo "Version $CURRENT_VERSION → $NEW_VERSION"
  CURRENT_VERSION="$NEW_VERSION"
fi

# ── 3. Version for electron-builder ────────────────────────────────
# electron-builder needs version WITHOUT 'v' prefix
VERSION_NUM="${CURRENT_VERSION#v}"

# ── 4. Build React frontend ────────────────────────────────────────
echo ""
echo "Building React frontend..."
pnpm exec vite build

# ── 5. Setup ffmpeg binaries ───────────────────────────────────────
echo "Ensuring macOS ffmpeg binaries..."
bin/setup-ffmpeg

# ── 6. Build macOS package ─────────────────────────────────────────
echo ""
echo "Building macOS app $CURRENT_VERSION..."
pnpm exec electron-builder --mac --publish never -c.extraMetadata.version="$VERSION_NUM"

# ── 7. Summary ─────────────────────────────────────────────────────
echo ""
echo "Build complete: $CURRENT_VERSION"
ls -lh dist/*.dmg 2>/dev/null || true

# ── 8. Publish to GitHub Releases ──────────────────────────────────
if $PUBLISH; then
  bin/publish

  echo ""
  echo "Cleaning dist/..."
  rm -rf dist
fi
