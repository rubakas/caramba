#!/usr/bin/env bash
#
# Download static ffmpeg + ffprobe binaries for bundling into the Electron app.
#
# macOS: https://evermeet.cx/ffmpeg/ (arm64/x86_64 universal static builds)
#
# Usage: bin/setup-ffmpeg           # skip if already present
#        bin/setup-ffmpeg --force   # re-download latest
#
set -euo pipefail

cd "$(dirname "$0")/.."

dir="vendor/ffmpeg"

FORCE=false
for arg in "$@"; do
  case "$arg" in
    --force) FORCE=true ;;
  esac
done

if [ "$FORCE" = false ] && [ -x "$dir/ffmpeg" ] && [ -x "$dir/ffprobe" ]; then
  echo "macOS ffmpeg already present:"
  "$dir/ffmpeg" -version | head -1
  exit 0
fi

# Require 7z for extraction
if ! command -v 7z &>/dev/null; then
  echo "Installing p7zip..."
  brew install p7zip
fi

mkdir -p "$dir"

echo "Downloading static ffmpeg (macOS)..."
curl -sL "https://evermeet.cx/ffmpeg/getrelease/ffmpeg/7z" -o /tmp/ffmpeg.7z

echo "Downloading static ffprobe (macOS)..."
curl -sL "https://evermeet.cx/ffmpeg/getrelease/ffprobe/7z" -o /tmp/ffprobe.7z

# Verify downloads are non-empty (basic integrity check)
for f in /tmp/ffmpeg.7z /tmp/ffprobe.7z; do
  if [ ! -s "$f" ]; then
    echo "Error: Downloaded file is empty: $f"
    exit 1
  fi
done

echo "Extracting..."
7z e /tmp/ffmpeg.7z -o"$dir" -y >/dev/null
7z e /tmp/ffprobe.7z -o"$dir" -y >/dev/null

chmod +x "$dir/ffmpeg" "$dir/ffprobe"

# Record checksums for audit/reproducibility
echo "Recording SHA256 checksums..."
shasum -a 256 "$dir/ffmpeg" "$dir/ffprobe" | tee "$dir/SHA256SUMS"

rm -f /tmp/ffmpeg.7z /tmp/ffprobe.7z

echo "Done:"
"$dir/ffmpeg" -version | head -1
ls -lh "$dir/"
