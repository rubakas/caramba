{
  "name": "@caramba/desktop",
  "version": "1.2.0",
  "description": "Caramba — personal media center",
  "author": "Vladyslav <vladyslav@hey.com>",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "vite build && electron .",
    "dist": "vite build && electron-builder --mac --x64 --arm64 --publish never"
  },
  "build": {
    "appId": "com.cupatea.caramba",
    "productName": "Caramba",
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.icns",
      "extraResources": [
        {
          "from": "vendor/ffmpeg-${arch}",
          "to": "ffmpeg"
        }
      ]
    },
    "files": [
      "electron/**/*",
      "dist-react/**/*"
    ],
    "asar": true
  },
  "dependencies": {
    "@caramba/ui": "workspace:*",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "react-router-dom": "^7.0.0",
    "vite": "^6.0.0"
  }
}
