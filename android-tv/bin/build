#!/usr/bin/env bash
#
# Build the Android TV app with auto version increment.
#
# Version format: MAJOR.MINOR.PATCH where PATCH auto-increments.
# If the last commit is already a version bump, the version stays the same.
#
# Usage: bin/build                        # Build only
#        bin/build --publish              # Build + publish to GitHub
#
set -euo pipefail

cd "$(dirname "$0")/.."

PACKAGE_JSON="package.json"

# ── 0. Parse flags ──────────────────────────────────────────────────
PUBLISH=false

for arg in "$@"; do
  case "$arg" in
    --publish) PUBLISH=true ;;
    *) echo "Unknown flag: $arg (use --publish)"; exit 1 ;;
  esac
done

# ── 1. Pre-flight checks ───────────────────────────────────────────
if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
  echo "Warning: You have uncommitted changes. Build will use the current working tree state."
fi

# Install dependencies
echo "Installing dependencies..."
cd ..
pnpm install
cd android-tv

# ── 2. Version increment ────────────────────────────────────────────
HEAD_MSG=$(git log -1 --format='%s' 2>/dev/null || echo "")
CURRENT_VERSION=$(node -e "console.log(require('./$PACKAGE_JSON').version)")

if [[ "$HEAD_MSG" == android-tv-v[0-9]* ]]; then
  echo "Version $CURRENT_VERSION (last commit is a version bump — skipping)"
else
  # Bump patch version
  IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT_VERSION"
  PATCH=$((PATCH + 1))
  NEW_VERSION="$MAJOR.$MINOR.$PATCH"

  # Update package.json and commit the bump
  node -e "
    const fs = require('fs');
    const pkg = JSON.parse(fs.readFileSync('$PACKAGE_JSON', 'utf-8'));
    pkg.version = '$NEW_VERSION';
    fs.writeFileSync('$PACKAGE_JSON', JSON.stringify(pkg, null, 2) + '\n');
  "
  git add "$PACKAGE_JSON"
  git commit -m "android-tv-v$NEW_VERSION" --no-verify

  echo "Version $CURRENT_VERSION → $NEW_VERSION"
  CURRENT_VERSION="$NEW_VERSION"
fi

# ── 3. Build React frontend ────────────────────────────────────────
echo ""
echo "Building React frontend..."
cd ../web
pnpm build
cd ../android-tv

# ── 4. Sync Capacitor ──────────────────────────────────────────────
echo ""
echo "Syncing Capacitor..."
npx cap sync android

# ── 5. Build Android APK ───────────────────────────────────────────
echo ""
echo "Building Android TV app v$CURRENT_VERSION..."
cd android
./gradlew clean assembleDebug

APK_PATH="app/build/outputs/apk/debug/app-debug.apk"
cd ..

# ── 6. Summary ─────────────────────────────────────────────────────
echo ""
echo "Build complete: v$CURRENT_VERSION"
ls -lh "android/$APK_PATH" 2>/dev/null || true

# ── 7. Publish to GitHub Releases ──────────────────────────────────
if $PUBLISH; then
  bin/publish

  echo ""
  echo "Cleaning build outputs..."
  rm -rf android/app/build/outputs
fi
