#!/usr/bin/env bash
#
# Build the Android TV app.
#
# Version is read from the root package.json (shared with desktop).
# Does NOT auto-increment version - use desktop/bin/build for that.
#
# Usage: bin/build                        # Build only
#        bin/build --publish              # Build + publish to GitHub
#
set -euo pipefail

cd "$(dirname "$0")/.."
ROOT_DIR="$(cd .. && pwd)"

ROOT_PACKAGE_JSON="$ROOT_DIR/package.json"

# ── Load .env.local (gitignored) for SENTRY_AUTH_TOKEN, SENTRY_ORG, etc. ────
if [ -f "$ROOT_DIR/.env.local" ]; then
  set -a
  # shellcheck disable=SC1091
  . "$ROOT_DIR/.env.local"
  set +a
fi

# ── 0. Parse flags ──────────────────────────────────────────────────
PUBLISH=false

for arg in "$@"; do
  case "$arg" in
    --publish) PUBLISH=true ;;
    *) echo "Unknown flag: $arg (use --publish)"; exit 1 ;;
  esac
done

# ── 1. Pre-flight checks ───────────────────────────────────────────
if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
  echo "Warning: You have uncommitted changes. Build will use the current working tree state."
fi

# Install dependencies
echo "Installing dependencies..."
cd "$ROOT_DIR"
pnpm install
cd android-tv

# ── 2. Get version ──────────────────────────────────────────────────
CURRENT_VERSION=$(node -e "console.log(require('$ROOT_PACKAGE_JSON').version)")
echo "Version: $CURRENT_VERSION"
export SENTRY_RELEASE="caramba@${CURRENT_VERSION#v}"
echo "Sentry release: $SENTRY_RELEASE"

# ── 3. Build React frontend ────────────────────────────────────────
echo ""
echo "Building React frontend..."
cd ../web
pnpm build --mode android
cd ../android-tv

# Always remove source maps from shipped artifacts.
find ../web/dist -name '*.js.map' -delete 2>/dev/null || true

# ── 4. Sync Capacitor ──────────────────────────────────────────────
echo ""
echo "Syncing Capacitor..."
npx cap sync android

# ── 5. Build Android APK ───────────────────────────────────────────
echo ""
echo "Building Android TV app $CURRENT_VERSION..."
cd android
VERSION_NUM="${CURRENT_VERSION#v}"
./gradlew clean assembleRelease -PappVersionName="$VERSION_NUM"

# Rename APK to include version
APK_DIR="app/build/outputs/apk/release"
APK_NAME="Caramba-${VERSION_NUM}-android-tv.apk"
mv "$APK_DIR/app-release.apk" "$APK_DIR/$APK_NAME"
APK_PATH="$APK_DIR/$APK_NAME"
cd ..

# ── 6. Summary ─────────────────────────────────────────────────────
echo ""
echo "Build complete: $CURRENT_VERSION"
ls -lh "android/$APK_PATH" 2>/dev/null || true

# ── 7. Publish to GitHub Releases ──────────────────────────────────
if $PUBLISH; then
  bin/publish

  echo ""
  echo "Cleaning build outputs..."
  rm -rf android/app/build/outputs
fi
