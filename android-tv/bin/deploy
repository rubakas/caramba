#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
ROOT_DIR="$(dirname "$PROJECT_DIR")"

# Chromecast device ID
DEVICE_ID="adb-22231HFDD5D22D-RoPAg4._adb-tls-connect._tcp"
ADB="$HOME/Library/Android/sdk/platform-tools/adb"

# Get version and find APK
CURRENT_VERSION=$(node -e "console.log(require('$ROOT_DIR/package.json').version)")
VERSION_NUM="${CURRENT_VERSION#v}"
APK_NAME="Caramba-${VERSION_NUM}-android-tv.apk"
APK_PATH="$PROJECT_DIR/android/app/build/outputs/apk/debug/$APK_NAME"

if [ ! -f "$APK_PATH" ]; then
  echo "No APK found: $APK_NAME"
  echo "Run 'bin/build' first."
  exit 1
fi

echo "Deploying to Chromecast..."
echo "APK: $APK_PATH"

# Install APK
"$ADB" -s "$DEVICE_ID" install -r "$APK_PATH"

echo "✓ Deployed successfully"
