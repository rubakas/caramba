<nav class="topnav">
  <a href="<%= root_path %>" class="topnav-brand">Series Tracker</a>
  <div class="topnav-links">
    <a href="<%= root_path %>" class="topnav-link">Library</a>
    <a href="<%= movies_path %>" class="topnav-link">Movies</a>
    <a href="<%= history_path %>" class="topnav-link">History</a>
  </div>
  <div class="topnav-actions">
    <%= button_to "Refresh", refresh_metadata_movie_path(@movie.slug), class: "topnav-btn" %>
    <%= button_to "Remove", movie_path(@movie.slug), method: :delete, class: "topnav-btn topnav-btn--danger",
        data: { turbo_confirm: "Remove '#{@movie.title}' from library?" } %>
  </div>
</nav>
<%# -- Now Playing -- %>
<div class="now-playing-bar" id="nowPlaying" style="display:none">
  <div class="np-dot"></div>
  <span class="np-label">Now Playing</span>
  <span class="np-title" id="npTitle"></span>
  <span class="np-time"><span id="npTime">0:00</span> / <span id="npDuration">0:00</span></span>
  <div class="np-progress">
    <div class="np-progress-fill" id="npBar" style="width:0%"></div>
  </div>
</div>
<%# -- Hero Section -- %>
<header class="show-hero" <% if @movie.has_poster? %>style="--poster: url(<%= @movie.poster_url %>)"<% end %>>
  <div class="show-hero-bg"></div>
  <div class="show-hero-content">
    <% if @movie.has_poster? %>
      <div class="show-poster">
        <img src="<%= @movie.poster_url %>" alt="<%= @movie.title %>">
      </div>
    <% end %>
    <div class="show-info">
      <h1 class="show-title"><%= @movie.title %></h1>
      <div class="show-meta-row">
        <% if @movie.year %><span><%= @movie.year %></span><% end %>
        <% if @movie.runtime_display %><span><%= @movie.runtime_display %></span><% end %>
        <% if @movie.rating %>
          <span class="show-rating">&#9733; <%= @movie.rating %></span>
        <% end %>
        <% if @movie.director.present? %>
          <span class="movie-director">Dir. <%= @movie.director %></span>
        <% end %>
        <% if @movie.imdb_id.present? %>
          <a href="https://www.imdb.com/title/<%= @movie.imdb_id %>/" target="_blank" class="show-imdb">IMDb</a>
        <% end %>
      </div>
      <% if @movie.genres_list.any? %>
        <div class="show-genres">
          <%= @movie.genres_list.join("  &middot;  ").html_safe %>
        </div>
      <% end %>
      <% if @movie.description.present? %>
        <p class="show-description"><%= @movie.description %></p>
      <% end %>
    </div>
  </div>
</header>
<main class="show-main">
  <%# -- Play / Resume CTA -- %>
  <% if @movie.in_progress? %>
    <div class="cta-card cta-resume">
      <div class="cta-content">
        <span class="cta-label">Resume Where You Left Off</span>
        <div class="cta-progress-row">
          <div class="cta-progress-track">
            <div class="cta-progress-fill" style="width:<%= @movie.progress_percent %>%"></div>
          </div>
          <span class="cta-progress-text"><%= @movie.formatted_progress %> (<%= @movie.progress_percent %>%)</span>
        </div>
      </div>
      <%= button_to play_movie_path(@movie.slug), class: "btn-play-cta btn-play-cta--resume" do %>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Resume
      <% end %>
    </div>
  <% else %>
    <div class="cta-card">
      <div class="cta-content">
        <span class="cta-label"><%= @movie.watched? ? 'Watch Again' : 'Start Watching' %></span>
        <div class="cta-episode">
          <span class="cta-ep-title"><%= @movie.title %></span>
        </div>
      </div>
      <%= button_to play_movie_path(@movie.slug), class: "btn-play-cta" do %>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Play
      <% end %>
    </div>
  <% end %>
  <%# -- Movie Info Cards -- %>
  <div class="movie-detail-section">
    <div class="stats-row">
      <% if @movie.runtime %>
        <div class="stat"><span class="stat-val"><%= @movie.runtime_display %></span><span class="stat-lbl">Runtime</span></div>
      <% end %>
      <% if @movie.rating %>
        <div class="stat"><span class="stat-val"><%= @movie.rating %></span><span class="stat-lbl">IMDb Rating</span></div>
      <% end %>
      <div class="stat">
        <span class="stat-val"><%= @movie.watched? ? '&#10003;' : '&mdash;' %></span>
        <span class="stat-lbl">Watched</span>
      </div>
    </div>
    <div class="movie-actions-row">
      <%= button_to toggle_movie_path(@movie.slug), class: "movie-toggle-btn" do %>
        <%= @movie.watched? ? 'Mark Unwatched' : 'Mark Watched' %>
      <% end %>
    </div>
    <% if @movie.file_path.present? %>
      <div class="movie-file-info">
        <span class="movie-file-label">File</span>
        <span class="movie-file-path"><%= File.basename(@movie.file_path) %></span>
      </div>
    <% end %>
  </div>
</main>
<script>
  var _wasPlaying = false;
  setInterval(function() {
    fetch("/playback/status")
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var np = document.getElementById("nowPlaying");
        if (data.playing) {
          _wasPlaying = true;
          np.style.display = "flex";
          document.getElementById("npTitle").textContent = data.movie_title || data.series_name + " — " + data.episode_code + " " + data.episode_title;
          document.getElementById("npTime").textContent = data.progress_display;
          document.getElementById("npDuration").textContent = data.duration_display;
          document.getElementById("npBar").style.width = (data.position * 100) + "%";
        } else {
          np.style.display = "none";
          if (_wasPlaying) { _wasPlaying = false; window.location.reload(); }
        }
      })
      .catch(function() {});
  }, 3000);
</script>
