<nav class="topnav">
  <a href="<%= root_path %>" class="topnav-brand">Series Tracker</a>
  <div class="topnav-links">
    <a href="<%= root_path %>" class="topnav-link">Library</a>
    <a href="<%= movies_path %>" class="topnav-link">Movies</a>
    <a href="<%= series_path(@series.slug) %>" class="topnav-link active">Episodes</a>
    <a href="<%= history_path %>" class="topnav-link">History</a>
    <a href="<%= settings_path %>" class="topnav-link">Settings</a>
  </div>
  <div class="topnav-actions">
    <%= button_to "Rescan", scan_series_path(@series.slug), class: "topnav-btn" %>
    <%= button_to "Refresh", refresh_metadata_series_path(@series.slug), class: "topnav-btn" %>
    <%= button_to "Remove", series_path(@series.slug), method: :delete, class: "topnav-btn topnav-btn--danger",
        data: { turbo_confirm: "Remove '#{@series.name}' and all its watch history?" } %>
  </div>
</nav>
<%# -- Now Playing -- %>
<div class="now-playing-bar" id="nowPlaying" style="display:none">
  <div class="np-dot"></div>
  <span class="np-label">Now Playing</span>
  <span class="np-title"><span id="npSeries"></span> &mdash; <span id="npTitle"></span></span>
  <span class="np-time"><span id="npTime">0:00</span> / <span id="npDuration">0:00</span></span>
  <div class="np-progress">
    <div class="np-progress-fill" id="npBar" style="width:0%"></div>
  </div>
</div>
<%# -- Hero Section with Poster + Metadata -- %>
<% if @series.has_metadata? %>
  <header class="show-hero" <% if @series.has_poster? %>style="--poster: url(<%= @series.poster_url %>)"<% end %>>
    <div class="show-hero-bg"></div>
    <div class="show-hero-content">
      <% if @series.has_poster? %>
        <div class="show-poster">
          <img src="<%= @series.poster_url %>" alt="<%= @series.name %>">
        </div>
      <% end %>
      <div class="show-info">
        <h1 class="show-title"><%= @series.name %></h1>
        <div class="show-meta-row">
          <% if @series.premiere_year %><span><%= @series.premiere_year %></span><% end %>
          <% if @series.status.present? %>
            <span class="show-status show-status--<%= @series.status.downcase.tr(' ', '-') %>"><%= @series.status %></span>
          <% end %>
          <% if @series.rating %>
            <span class="show-rating">&#9733; <%= @series.rating %></span>
          <% end %>
          <% if @series.imdb_id.present? %>
            <a href="https://www.imdb.com/title/<%= @series.imdb_id %>/" target="_blank" class="show-imdb">IMDb</a>
          <% end %>
        </div>
        <% if @series.genres_list.any? %>
          <div class="show-genres">
            <%= @series.genres_list.join("  &middot;  ").html_safe %>
          </div>
        <% end %>
        <% if @series.description.present? %>
          <p class="show-description"><%= @series.description %></p>
        <% end %>
      </div>
    </div>
  </header>
<% end %>
<main class="show-main">
  <% if @seasons.empty? %>
    <div class="empty-hero" style="padding:60px 0">
      <h2>No episodes found</h2>
      <p>Scan the media folder to load episodes.</p>
      <%= button_to "Scan Media Folder", scan_series_path(@series.slug), class: "btn-primary" %>
    </div>
  <% else %>
    <%# -- Continue Watching Banners -- %>
    <% if @resume_episode && @resume_episode != @next_episode %>
      <div class="cta-card cta-resume">
        <div class="cta-content">
          <span class="cta-label">Resume Where You Left Off</span>
          <div class="cta-episode">
            <span class="cta-code"><%= @resume_episode.code %></span>
            <span class="cta-ep-title"><%= @resume_episode.title %></span>
          </div>
          <div class="cta-progress-row">
            <div class="cta-progress-track">
              <div class="cta-progress-fill" style="width:<%= @resume_episode.progress_percent %>%"></div>
            </div>
            <span class="cta-progress-text"><%= @resume_episode.formatted_progress %> (<%= @resume_episode.progress_percent %>%)</span>
          </div>
        </div>
        <%= button_to play_series_episode_path(@series.slug, @resume_episode), class: "btn-play-cta btn-play-cta--resume" do %>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Resume
        <% end %>
      </div>
    <% end %>
    <% if @next_episode %>
      <div class="cta-card">
        <div class="cta-content">
          <span class="cta-label">Up Next</span>
          <div class="cta-episode">
            <span class="cta-code"><%= @next_episode.code %></span>
            <span class="cta-ep-title"><%= @next_episode.title %></span>
          </div>
          <% if @next_episode.description.present? %>
            <p class="cta-desc"><%= truncate(@next_episode.description, length: 150) %></p>
          <% end %>
        </div>
        <%= button_to play_series_episode_path(@series.slug, @next_episode), class: "btn-play-cta" do %>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          <%= @next_episode.in_progress? ? "Resume" : "Play" %>
        <% end %>
      </div>
    <% elsif @last_watched.nil? %>
      <% first_ep = @seasons.values.first&.first %>
      <% if first_ep %>
        <div class="cta-card">
          <div class="cta-content">
            <span class="cta-label">Start Watching</span>
            <div class="cta-episode">
              <span class="cta-code"><%= first_ep.code %></span>
              <span class="cta-ep-title"><%= first_ep.title %></span>
            </div>
          </div>
          <%= button_to play_series_episode_path(@series.slug, first_ep), class: "btn-play-cta" do %>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Play
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="cta-card">
        <div class="cta-content">
          <span class="cta-label">All Caught Up</span>
          <div class="cta-episode">
            <span class="cta-ep-title">You've watched all <%= @seasons.keys.size %> seasons</span>
          </div>
        </div>
      </div>
    <% end %>
    <%# -- Stats Row -- %>
    <% total = @series.total_episodes; watched_count = @series.watched_episodes %>
    <% total_watch_time = @series.total_watch_time %>
    <div class="stats-row">
      <div class="stat"><span class="stat-val"><%= @seasons.keys.size %></span><span class="stat-lbl">Seasons</span></div>
      <div class="stat"><span class="stat-val"><%= total %></span><span class="stat-lbl">Episodes</span></div>
      <div class="stat"><span class="stat-val"><%= watched_count %></span><span class="stat-lbl">Watched</span></div>
      <% if total > 0 %>
        <div class="stat"><span class="stat-val"><%= (watched_count * 100 / total) %>%</span><span class="stat-lbl">Complete</span></div>
      <% end %>
      <% if total_watch_time > 0 %>
        <div class="stat"><span class="stat-val"><%= (total_watch_time / 3600.0).round(1) %></span><span class="stat-lbl">Hours</span></div>
      <% end %>
    </div>
    <%# -- Season Tabs -- %>
    <% active_season = @last_watched&.season_number || @seasons.keys.first %>
    <div class="season-tabs" id="seasonPicker">
      <% @seasons.each do |season_num, episodes| %>
        <% watched_in_season = episodes.count(&:watched?) %>
        <% pct = episodes.any? ? (watched_in_season * 100 / episodes.size) : 0 %>
        <button
        class="season-tab<%= ' active' if season_num == active_season %>"
        data-season="<%= season_num %>"
        onclick="selectSeason(<%= season_num %>)"
      >
          <%= season_num == 0 ? 'Specials' : "Season #{season_num}" %>
          <% if pct == 100 %>
            <span class="season-check">&#10003;</span>
          <% elsif pct > 0 %>
            <span class="season-pct"><%= pct %>%</span>
          <% end %>
        </button>
      <% end %>
    </div>
    <%# -- Season Panels -- %>
    <% @seasons.each do |season_num, episodes| %>
      <% watched_in_season = episodes.count(&:watched?) %>
      <% pct = episodes.any? ? (watched_in_season * 100 / episodes.size) : 0 %>
      <section class="season-panel<%= ' active' if season_num == active_season %>" id="panel-<%= season_num %>">
        <div class="season-header">
          <h2><%= season_num == 0 ? 'Specials' : "Season #{season_num}" %></h2>
          <span class="season-detail"><%= episodes.size %> episodes &middot; <%= watched_in_season %> watched</span>
          <div class="season-bar">
            <div class="season-bar-fill" style="width:<%= pct %>%"></div>
          </div>
        </div>
        <div class="ep-list">
          <% episodes.each do |ep| %>
            <div class="ep-row<%= ' ep-row--watched' if ep.watched? %><%= ' ep-row--current' if @last_watched && @last_watched.id == ep.id %>">
              <div class="ep-num">
                <% if ep.watched? %>
                  <span class="ep-watched-icon">&#10003;</span>
                <% else %>
                  <span class="ep-episode-num"><%= ep.episode_number %></span>
                <% end %>
              </div>
              <div class="ep-body">
                <div class="ep-top-row">
                  <span class="ep-name"><%= ep.title %></span>
                  <% if ep.air_date.present? %>
                    <span class="ep-date"><%= ep.air_date %></span>
                  <% end %>
                </div>
                <span class="ep-code-label"><%= ep.code %></span>
                <% if ep.description.present? %>
                  <% truncated = truncate(ep.description, length: 120) %>
                  <% if truncated != ep.description %>
                    <p class="ep-desc expandable" onclick="this.classList.toggle('expanded')">
                      <span class="ep-desc-short"><%= truncated %></span>
                      <span class="ep-desc-full"><%= ep.description %></span>
                    </p>
                  <% else %>
                    <p class="ep-desc"><%= ep.description %></p>
                  <% end %>
                <% end %>
                <% if ep.in_progress? %>
                  <div class="ep-progress">
                    <div class="ep-progress-track">
                      <div class="ep-progress-fill" style="width:<%= ep.progress_percent %>%"></div>
                    </div>
                    <span class="ep-progress-label"><%= ep.formatted_progress %></span>
                  </div>
                <% end %>
              </div>
              <div class="ep-actions">
                <%= button_to play_series_episode_path(@series.slug, ep), class: "btn-ep-play" do %>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                <% end %>
                <%= button_to toggle_series_episode_path(@series.slug, ep), class: "btn-ep-toggle" do %>
                  <%= ep.watched? ? "Unwatch" : "Watched" %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>
  <% end %>
</main>
<script>
  function selectSeason(num) {
    document.querySelectorAll('.season-tab').forEach(function(t) {
      t.classList.toggle('active', parseInt(t.dataset.season) === num);
    });
    document.querySelectorAll('.season-panel').forEach(function(p) {
      p.classList.toggle('active', p.id === 'panel-' + num);
    });
    var active = document.querySelector('.season-tab.active');
    if (active) active.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
  }

  var _wasPlaying = false;
  setInterval(function() {
    fetch("/playback/status")
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var np = document.getElementById("nowPlaying");
        if (data.playing) {
          _wasPlaying = true;
          np.style.display = "flex";
          document.getElementById("npSeries").textContent = data.series_name || "";
          document.getElementById("npTitle").textContent = data.episode_code + " " + data.episode_title;
          document.getElementById("npTime").textContent = data.progress_display;
          document.getElementById("npDuration").textContent = data.duration_display;
          document.getElementById("npBar").style.width = (data.position * 100) + "%";
        } else {
          np.style.display = "none";
          if (_wasPlaying) { _wasPlaying = false; window.location.reload(); }
        }
      })
      .catch(function() {});
  }, 3000);
</script>
