<nav class="topnav">
  <a href="<%= root_path %>" class="topnav-brand">Series Tracker</a>
  <div class="topnav-links">
    <a href="<%= root_path %>" class="topnav-link">Library</a>
    <a href="<%= movies_path %>" class="topnav-link">Movies</a>
    <a href="<%= history_path %>" class="topnav-link">History</a>
    <a href="<%= settings_path %>" class="topnav-link">Settings</a>
  </div>
</nav>
<main class="add-main">
  <div class="add-container">
    <h1 class="page-title">Add Series</h1>
    <p class="add-help">
      Choose a folder that contains MKV files with SxxExx naming.<br>
      The series name will be auto-detected from the folder name.
    </p>
    <% if flash[:alert] %>
      <div class="alert"><%= flash[:alert] %></div>
    <% end %>
    <%= form_with url: series_index_path, method: :post, class: "add-form", id: "addForm" do |f| %>
      <input type="hidden" name="media_path" id="media_path">
      <%# Electron mode: folder picker button %>
      <div class="field" id="electronPicker" style="display:none">
        <div class="folder-picker">
          <button type="button" class="btn-choose-folder" id="chooseBtn">Choose Folder...</button>
          <span class="folder-path" id="folderDisplay">No folder selected</span>
        </div>
      </div>
      <%# Browser fallback: text input %>
      <div class="field" id="browserInput">
        <label for="media_path_text">Media Folder Path</label>
        <input type="text" id="media_path_text"
               value="<%= params[:media_path] %>"
               placeholder="/path/to/Show.Name.Year..."
               class="field-input"
               autofocus>
      </div>
      <div class="add-actions">
        <button type="submit" class="btn-primary" id="submitBtn">Scan & Add</button>
      </div>
    <% end %>
  </div>
</main>
<script>
  (function() {
    var hiddenInput = document.getElementById('media_path');
    var electronPicker = document.getElementById('electronPicker');
    var browserInput = document.getElementById('browserInput');
    var textInput = document.getElementById('media_path_text');
    var chooseBtn = document.getElementById('chooseBtn');
    var folderDisplay = document.getElementById('folderDisplay');
    var form = document.getElementById('addForm');

    var submitBtn = document.getElementById('submitBtn');

    if (window.electronAPI && window.electronAPI.selectFolder) {
      // Electron mode: show folder picker, hide text input, hide submit until folder chosen
      electronPicker.style.display = '';
      browserInput.style.display = 'none';
      submitBtn.style.display = 'none';

      chooseBtn.addEventListener('click', function() {
        window.electronAPI.selectFolder().then(function(folderPath) {
          if (folderPath) {
            hiddenInput.value = folderPath;
            folderDisplay.textContent = folderPath;
            folderDisplay.classList.add('has-path');
            submitBtn.style.display = '';
          }
        });
      });
    } else {
      // Browser dev mode: sync text input to hidden input on submit
      form.addEventListener('submit', function() {
        hiddenInput.value = textInput.value;
      });
    }
  })();
</script>
