<nav class="topnav">
  <a href="<%= root_path %>" class="topnav-brand">Series Tracker</a>
  <div class="topnav-links">
    <a href="<%= root_path %>" class="topnav-link active">Library</a>
    <a href="<%= movies_path %>" class="topnav-link">Movies</a>
    <a href="<%= history_path %>" class="topnav-link">History</a>
  </div>
  <a href="<%= new_series_path %>" class="topnav-action">+ Add Series</a>
</nav>
<%# -- Now Playing -- %>
<div class="now-playing-bar" id="nowPlaying" style="display:none">
  <div class="np-dot"></div>
  <span class="np-label">Now Playing</span>
  <span class="np-title"><span id="npSeries"></span> &mdash; <span id="npTitle"></span></span>
  <span class="np-time"><span id="npTime">0:00</span> / <span id="npDuration">0:00</span></span>
  <div class="np-progress">
    <div class="np-progress-fill" id="npBar" style="width:0%"></div>
  </div>
</div>
<% if @all_series.empty? %>
  <main class="empty-hero">
    <div class="empty-icon">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/><line x1="17" y1="17" x2="22" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/></svg>
    </div>
    <h2>Your Library is Empty</h2>
    <p>Add a series by pointing to a media folder on your Mac.</p>
    <a href="<%= new_series_path %>" class="btn-primary">Add Your First Series</a>
  </main>
<% else %>
  <main class="library">
    <h2 class="section-title">My Library</h2>
    <div class="series-grid">
      <% @all_series.each do |s| %>
        <a href="<%= series_path(s.slug) %>" class="series-card">
          <div class="card-poster">
            <% if s.has_poster? %>
              <img src="<%= s.poster_url %>" alt="<%= s.name %>" loading="lazy">
            <% else %>
              <div class="card-poster-fallback"><%= s.name[0] %></div>
            <% end %>
            <div class="card-overlay">
              <% if s.rating %>
                <span class="card-rating"><%= s.rating %></span>
              <% end %>
              <% if s.resumable_episode %>
                <span class="card-badge-resume">Resume</span>
              <% end %>
            </div>
            <% if s.watched_episodes > 0 %>
              <div class="card-progress-track">
                <div class="card-progress-fill" style="width:<%= s.progress_percent %>%"></div>
              </div>
            <% end %>
          </div>
          <div class="card-body">
            <h3 class="card-title"><%= s.name %></h3>
            <p class="card-meta">
              <% if s.premiere_year %><%= s.premiere_year %><% end %>
              <% if s.status.present? %>
                <span class="card-status card-status--<%= s.status.downcase.tr(' ', '-') %>"><%= s.status %></span>
              <% end %>
            </p>
            <% if s.genres_list.any? %>
              <div class="card-genres">
                <%= s.genres_list.first(3).join("  &middot;  ").html_safe %>
              </div>
            <% end %>
            <% if s.watched_episodes > 0 %>
              <p class="card-progress-label"><%= s.watched_episodes %>/<%= s.total_episodes %> episodes</p>
            <% end %>
          </div>
        </a>
      <% end %>
      <a href="<%= new_series_path %>" class="series-card card-add">
        <div class="card-poster">
          <div class="card-poster-fallback card-add-icon">+</div>
        </div>
        <div class="card-body">
          <h3 class="card-title">Add Series</h3>
          <p class="card-meta">From a local folder</p>
        </div>
      </a>
    </div>
  </main>
<% end %>
<script>
  var _wasPlaying = false;
  setInterval(function() {
    fetch("/playback/status")
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var np = document.getElementById("nowPlaying");
        if (data.playing) {
          _wasPlaying = true;
          np.style.display = "flex";
          document.getElementById("npSeries").textContent = data.series_name || "";
          document.getElementById("npTitle").textContent = data.episode_code + " " + data.episode_title;
          document.getElementById("npTime").textContent = data.progress_display;
          document.getElementById("npDuration").textContent = data.duration_display;
          document.getElementById("npBar").style.width = (data.position * 100) + "%";
        } else {
          np.style.display = "none";
          if (_wasPlaying) { _wasPlaying = false; window.location.reload(); }
        }
      })
      .catch(function() {});
  }, 3000);
</script>
