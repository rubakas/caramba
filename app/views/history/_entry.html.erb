<div class="history-entry">
  <div class="history-entry-left">
    <span class="history-series"><%= h.episode.series.name %></span>
    <span class="history-code"><%= h.episode.code %></span>
  </div>
  <div class="history-entry-mid">
    <span class="history-ep-title"><%= h.episode.title %></span>
    <span class="history-meta">
      <%= h.started_at.strftime("%b %d, %Y at %H:%M") %>
      <% if h.progress_seconds&.positive? && h.duration_seconds&.positive? %>
        &mdash; <%= h.progress_percent %>%
        (<%= format_time(h.progress_seconds) %> / <%= format_time(h.duration_seconds) %>)
      <% end %>
      <% if h.finished? %>
        <span class="badge badge--green">Completed</span>
      <% elsif h.progress_seconds&.positive? %>
        <span class="badge badge--amber">Partial</span>
      <% end %>
    </span>
  </div>
  <div class="history-entry-right">
    <%= button_to play_series_episode_path(h.episode.series.slug, h.episode), class: "btn-ep-play" do %>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
    <% end %>
  </div>
</div>
