<nav class="topnav">
  <a href="<%= root_path %>" class="topnav-brand">Series Tracker</a>
  <div class="topnav-links">
    <a href="<%= root_path %>" class="topnav-link">Library</a>
    <a href="<%= movies_path %>" class="topnav-link">Movies</a>
    <a href="<%= history_path %>" class="topnav-link active">History</a>
    <a href="<%= settings_path %>" class="topnav-link">Settings</a>
  </div>
</nav>
<main class="history-main">
  <h1 class="page-title">Watch History</h1>
  <div class="stats-row" style="margin-bottom:40px">
    <div class="stat"><span class="stat-val"><%= @total_series %></span><span class="stat-lbl">Series</span></div>
    <div class="stat"><span class="stat-val"><%= @total_episodes %></span><span class="stat-lbl">Episodes</span></div>
    <div class="stat"><span class="stat-val"><%= (@total_time / 3600.0).round(1) %></span><span class="stat-lbl">Hours</span></div>
    <div class="stat"><span class="stat-val"><%= @histories.count %></span><span class="stat-lbl">Sessions</span></div>
  </div>
  <% if @histories.empty? %>
    <div class="empty-hero" style="padding:40px 0">
      <h2>No watch history yet</h2>
      <p>Start watching episodes and your history will appear here.</p>
      <a href="<%= root_path %>" class="btn-primary">Browse Library</a>
    </div>
  <% else %>
    <% if @today.any? %>
      <section class="history-section">
        <h2 class="history-section-title">Today</h2>
        <% @today.each do |h| %>
          <%= render partial: "history/entry", locals: { h: h } %>
        <% end %>
      </section>
    <% end %>
    <% if @this_week.any? %>
      <section class="history-section">
        <h2 class="history-section-title">This Week</h2>
        <% @this_week.each do |h| %>
          <%= render partial: "history/entry", locals: { h: h } %>
        <% end %>
      </section>
    <% end %>
    <% if @older.any? %>
      <section class="history-section">
        <h2 class="history-section-title">Earlier</h2>
        <% @older.each do |h| %>
          <%= render partial: "history/entry", locals: { h: h } %>
        <% end %>
      </section>
    <% end %>
  <% end %>
</main>
