<nav class="topnav">
  <a href="<%= root_path %>" class="topnav-brand">Series Tracker</a>
  <div class="topnav-links">
    <a href="<%= root_path %>" class="topnav-link">Library</a>
    <a href="<%= movies_path %>" class="topnav-link">Movies</a>
    <a href="<%= history_path %>" class="topnav-link">History</a>
    <a href="<%= settings_path %>" class="topnav-link active">Settings</a>
  </div>
</nav>
<main class="settings-main">
  <h1 class="page-title">Settings</h1>
  <% if flash[:notice] %>
    <div class="alert alert--success"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="alert"><%= flash[:alert] %></div>
  <% end %>
  <%# -- Sync Folder Section -- %>
  <section class="settings-section">
    <h2 class="settings-section-title">Database Sync</h2>
    <p class="settings-help">
      Choose a shared folder (Dropbox, iCloud, NAS, etc.) to sync your database between machines.
      The app checks every 30 seconds and loads whichever copy is newer.
    </p>
    <%= form_with url: settings_path, method: :patch, class: "settings-form", id: "syncForm" do |f| %>
      <input type="hidden" name="sync_folder" id="sync_folder" value="<%= @sync_folder %>">
      <%# Electron mode: folder picker %>
      <div class="field" id="electronPicker" style="display:none">
        <div class="folder-picker">
          <button type="button" class="btn-choose-folder" id="chooseSyncBtn">
            <%= @sync_folder.present? ? 'Change Folder...' : 'Choose Sync Folder...' %>
          </button>
          <span class="folder-path<%= ' has-path' if @sync_folder.present? %>" id="syncFolderDisplay">
            <%= @sync_folder.present? ? @sync_folder : 'No folder selected' %>
          </span>
        </div>
      </div>
      <%# Browser fallback: text input %>
      <div class="field" id="browserInput">
        <label for="sync_folder_text">Sync Folder Path</label>
        <input type="text" id="sync_folder_text"
               value="<%= @sync_folder %>"
               placeholder="/path/to/shared/folder"
               class="field-input">
      </div>
      <div class="settings-actions">
        <button type="submit" class="btn-primary">Save</button>
        <% if @sync_folder.present? %>
          <button type="submit" formaction="<%= settings_path %>" name="sync_folder" value="" class="btn-ghost">Disable Sync</button>
        <% end %>
      </div>
    <% end %>
  </section>
  <%# -- Sync Status Section -- %>
  <% if @status[:enabled] %>
    <section class="settings-section">
      <h2 class="settings-section-title">Sync Status</h2>
      <div class="sync-status-grid">
        <div class="sync-status-card">
          <span class="sync-status-label">Local Database</span>
          <span class="sync-status-value"><%= number_to_human_size(@status[:local_size] || 0) %></span>
          <span class="sync-status-detail">
            Modified: <%= @status[:local_mtime]&.strftime('%b %d, %Y %H:%M:%S') || 'N/A' %>
          </span>
        </div>
        <div class="sync-status-card">
          <span class="sync-status-label">Sync Copy</span>
          <% if @status[:remote_exists] %>
            <span class="sync-status-value"><%= number_to_human_size(@status[:remote_size] || 0) %></span>
            <span class="sync-status-detail">
              Modified: <%= @status[:remote_mtime]&.strftime('%b %d, %Y %H:%M:%S') || 'N/A' %>
            </span>
          <% else %>
            <span class="sync-status-value sync-status-value--none">Not yet synced</span>
          <% end %>
        </div>
        <div class="sync-status-card">
          <span class="sync-status-label">Last Sync</span>
          <span class="sync-status-value">
            <%= @status[:last_synced_at]&.strftime('%H:%M:%S') || 'Never' %>
          </span>
          <span class="sync-status-detail">
            Background sync: <%= @status[:sync_running] ? 'Running' : 'Stopped' %>
          </span>
        </div>
      </div>
      <div class="settings-actions" style="margin-top: 20px">
        <%= button_to "Sync Now", sync_now_settings_path, class: "btn-primary" %>
        <% if @status[:remote_exists] %>
          <%= button_to "Load from Sync Folder", load_from_sync_settings_path, class: "btn-ghost",
              data: { turbo_confirm: "This will replace your local database with the sync folder copy. Continue?" } %>
        <% end %>
      </div>
    </section>
  <% end %>
</main>
<script>
  (function() {
    var hiddenInput = document.getElementById('sync_folder');
    var electronPicker = document.getElementById('electronPicker');
    var browserInput = document.getElementById('browserInput');
    var textInput = document.getElementById('sync_folder_text');
    var chooseBtn = document.getElementById('chooseSyncBtn');
    var folderDisplay = document.getElementById('syncFolderDisplay');
    var form = document.getElementById('syncForm');

    if (window.electronAPI && window.electronAPI.selectFolder) {
      electronPicker.style.display = '';
      browserInput.style.display = 'none';

      chooseBtn.addEventListener('click', function() {
        window.electronAPI.selectFolder().then(function(folderPath) {
          if (folderPath) {
            hiddenInput.value = folderPath;
            folderDisplay.textContent = folderPath;
            folderDisplay.classList.add('has-path');
          }
        });
      });
    } else {
      form.addEventListener('submit', function() {
        hiddenInput.value = textInput.value;
      });
    }
  })();
</script>
