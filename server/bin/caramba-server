#!/bin/bash
# Launcher script for launchd — starts Rails in production mode.
# Called by com.caramba.server.plist.

set -e

# Always use the /current symlink so restarts pick up new releases
cd /opt/caramba/current/server

# Ensure mise shims are on PATH
export PATH="$HOME/.local/share/mise/shims:/opt/homebrew/bin:/usr/local/bin:$PATH"

# Run pending migrations (idempotent — safe to run every start)
bundle exec rails db:prepare

# Start Puma (foreground — launchd manages the process lifecycle)
exec bundle exec rails server -e production -p "${PORT:-3000}"
