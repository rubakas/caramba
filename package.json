{
  "name": "caramba",
  "version": "1.0.17",
  "description": "Caramba — Apple TV+ style episode tracker",
  "author": "Vladyslav <vladyslav@hey.com>",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "vite build && electron .",
    "dist": "vite build && electron-builder --mac --x64 --arm64 --publish never",
    "dist:linux": "bin/build --linux"
  },
  "build": {
    "appId": "com.cupatea.caramba",
    "productName": "Caramba",
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "public/icon.icns",
      "extraResources": [
        {
          "from": "vendor/ffmpeg",
          "to": "ffmpeg"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "AudioVideo",
      "icon": "public/icon.png",
      "extraResources": [
        {
          "from": "vendor/ffmpeg-linux",
          "to": "ffmpeg"
        }
      ]
    },
    "files": [
      "electron/**/*",
      "dist-react/**/*"
    ],
    "asar": true
  },
  "dependencies": {
    "@hashintel/refractive": "^0.0.3",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "react-router-dom": "^7.0.0",
    "vite": "^6.0.0"
  }
}
