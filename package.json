{
  "name": "caramba",
  "version": "1.0.0",
  "description": "Caramba — Apple TV+ style episode tracker",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "vite build && electron .",
    "dist": "vite build && electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.cupatea.caramba",
    "productName": "Caramba",
    "mac": {
      "category": "public.app-category.entertainment",
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "files": [
      "electron/**/*",
      "dist-react/**/*"
    ],
    "extraResources": [
      {
        "from": "storage",
        "to": "storage"
      }
    ],
    "asar": true
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "react-router-dom": "^7.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^6.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
