{
  "name": "series-tracker",
  "version": "1.0.1",
  "description": "Series Tracker — Apple TV+ style episode tracker",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "bundle": "script/bundle-ruby",
    "dist": "script/bundle-ruby && electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.cupatea.series-tracker",
    "productName": "Series Tracker",
    "mac": {
      "category": "public.app-category.entertainment",
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build/bundle",
        "to": "bundle"
      }
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
