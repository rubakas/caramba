#!/usr/bin/env bash
#
# Build the packaged app with auto version increment.
#
# Version format: MAJOR.MINOR.PATCH where PATCH auto-increments.
# The last-built commit hash is stored in .build-commit. If HEAD
# matches that hash, the version stays the same (idempotent rebuild).
#
# Usage: bin/build                        # Mac + Linux, no publish
#        bin/build --mac                  # Mac only
#        bin/build --linux                # Linux only
#        bin/build --publish              # Mac + Linux + publish to GitHub
#        bin/build --mac --publish        # Mac + publish
#
set -euo pipefail

cd "$(dirname "$0")/.."

BUILD_COMMIT_FILE=".build-commit"
PACKAGE_JSON="package.json"

# ── 0. Parse flags (default: both platforms, no publish) ─────────────
BUILD_MAC=false
BUILD_LINUX=false
PUBLISH=false

if [ $# -eq 0 ]; then
  BUILD_MAC=true
  BUILD_LINUX=true
else
  for arg in "$@"; do
    case "$arg" in
      --mac)     BUILD_MAC=true ;;
      --linux)   BUILD_LINUX=true ;;
      --publish) PUBLISH=true ;;
      *) echo "Unknown flag: $arg (use --mac, --linux, --publish)"; exit 1 ;;
    esac
  done
  # If only --publish was passed with no platform, default to both
  if ! $BUILD_MAC && ! $BUILD_LINUX; then
    BUILD_MAC=true
    BUILD_LINUX=true
  fi
fi

# ── 1. Version increment ────────────────────────────────────────────
HEAD_HASH=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
HEAD_MSG=$(git log -1 --format='%s' 2>/dev/null || echo "")
LAST_HASH=$(cat "$BUILD_COMMIT_FILE" 2>/dev/null || echo "")

CURRENT_VERSION=$(node -e "console.log(require('./$PACKAGE_JSON').version)")

if [ "$HEAD_HASH" = "$LAST_HASH" ]; then
  echo "Version $CURRENT_VERSION (same commit: $HEAD_HASH — $HEAD_MSG)"
else
  # Bump patch version
  IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT_VERSION"
  PATCH=$((PATCH + 1))
  NEW_VERSION="$MAJOR.$MINOR.$PATCH"

  # Update package.json
  node -e "
    const fs = require('fs');
    const pkg = JSON.parse(fs.readFileSync('$PACKAGE_JSON', 'utf-8'));
    pkg.version = '$NEW_VERSION';
    fs.writeFileSync('$PACKAGE_JSON', JSON.stringify(pkg, null, 2) + '\n');
  "

  echo "Version $CURRENT_VERSION → $NEW_VERSION ($HEAD_HASH — $HEAD_MSG)"
  CURRENT_VERSION="$NEW_VERSION"

  # Record commit immediately so a failed build doesn't re-bump next run
  echo "$HEAD_HASH" > "$BUILD_COMMIT_FILE"
fi

# ── 2. Build React frontend ────────────────────────────────────────
echo ""
echo "Building React frontend..."
npx vite build

# ── 3. Build platform packages ─────────────────────────────────────
TARGETS=""
$BUILD_MAC   && TARGETS="$TARGETS --mac"
$BUILD_LINUX && TARGETS="$TARGETS --linux"

echo ""
echo "Building Electron app v$CURRENT_VERSION ($TARGETS)..."
npx electron-builder $TARGETS --publish never

# ── 4. Summary ─────────────────────────────────────────────────────

echo ""
echo "Build complete: v$CURRENT_VERSION"
ls -lh dist/*.dmg 2>/dev/null || true
ls -lh dist/*.AppImage 2>/dev/null || true
ls -lh dist/*.deb 2>/dev/null || true

# ── 5. Publish to GitHub Releases ──────────────────────────────────
if $PUBLISH; then
  echo ""

  # Require gh CLI
  if ! command -v gh &>/dev/null; then
    echo "Error: gh CLI not found. Install it: brew install gh"
    exit 1
  fi

  # Collect artifacts
  ARTIFACTS=()
  for f in dist/*.dmg dist/*.AppImage dist/*.deb; do
    [ -f "$f" ] && ARTIFACTS+=("$f")
  done

  if [ ${#ARTIFACTS[@]} -eq 0 ]; then
    echo "Warning: No artifacts found in dist/ — skipping publish."
    exit 0
  fi

  TAG="v$CURRENT_VERSION"
  echo "Publishing $TAG to GitHub Releases..."
  echo "  Assets: ${ARTIFACTS[*]}"

  # Check if release already exists for this tag
  if gh release view "$TAG" &>/dev/null; then
    echo "  Release $TAG already exists — uploading assets (overwrite)..."
    gh release upload "$TAG" "${ARTIFACTS[@]}" --clobber
  else
    gh release create "$TAG" "${ARTIFACTS[@]}" \
      --title "$TAG" \
      --notes "$HEAD_MSG" \
      --latest
  fi

  echo ""
  echo "Published: $(gh release view "$TAG" --json url -q '.url')"
fi
