#!/usr/bin/env bash
#
# Build the packaged app with auto version increment.
#
# Version format: MAJOR.MINOR.PATCH where PATCH auto-increments.
# The last-built commit hash is stored in .build-commit. If HEAD
# matches that hash, the version stays the same (idempotent rebuild).
#
# When building for Linux on macOS, Docker is used automatically to
# cross-compile native modules (better-sqlite3) for the correct arch.
#
# Usage: bin/build                        # Mac + Linux, no publish
#        bin/build --mac                  # Mac only
#        bin/build --linux                # Linux only
#        bin/build --publish              # Mac + Linux + publish to GitHub
#        bin/build --mac --publish        # Mac + publish
#
set -euo pipefail

cd "$(dirname "$0")/.."

PACKAGE_JSON="package.json"

# ── 0. Parse flags (default: both platforms, no publish) ─────────────
BUILD_MAC=false
BUILD_LINUX=false
PUBLISH=false

if [ $# -eq 0 ]; then
  BUILD_MAC=true
  BUILD_LINUX=true
else
  for arg in "$@"; do
    case "$arg" in
      --mac)     BUILD_MAC=true ;;
      --linux)   BUILD_LINUX=true ;;
      --publish) PUBLISH=true ;;
      *) echo "Unknown flag: $arg (use --mac, --linux, --publish)"; exit 1 ;;
    esac
  done
  # If only --publish was passed with no platform, default to both
  if ! $BUILD_MAC && ! $BUILD_LINUX; then
    BUILD_MAC=true
    BUILD_LINUX=true
  fi
fi

# ── 1. Pre-flight checks ───────────────────────────────────────────
# Ensure working directory is clean (uncommitted changes can cause confusion)
if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
  echo "Warning: You have uncommitted changes. Build will use the current working tree state."
fi

# ── 2. Version increment ────────────────────────────────────────────
# Skip bumping if the last commit is already a version bump from this script.
# This prevents an infinite loop: bump → commit → build → see new commit → bump again.
HEAD_MSG=$(git log -1 --format='%s' 2>/dev/null || echo "")
CURRENT_VERSION=$(node -e "console.log(require('./$PACKAGE_JSON').version)")

if [[ "$HEAD_MSG" == v[0-9]* ]]; then
  echo "Version $CURRENT_VERSION (last commit is a version bump — skipping)"
else
  # Bump patch version
  IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT_VERSION"
  PATCH=$((PATCH + 1))
  NEW_VERSION="$MAJOR.$MINOR.$PATCH"

  # Update package.json and commit the bump
  node -e "
    const fs = require('fs');
    const pkg = JSON.parse(fs.readFileSync('$PACKAGE_JSON', 'utf-8'));
    pkg.version = '$NEW_VERSION';
    fs.writeFileSync('$PACKAGE_JSON', JSON.stringify(pkg, null, 2) + '\n');
  "
  git add "$PACKAGE_JSON"
  git commit -m "v$NEW_VERSION" --no-verify

  echo "Version $CURRENT_VERSION → $NEW_VERSION"
  CURRENT_VERSION="$NEW_VERSION"
fi

# ── 3. Build React frontend ────────────────────────────────────────
echo ""
echo "Building React frontend..."
npx vite build

# ── 4. Setup ffmpeg binaries for target platforms ──────────────────
if $BUILD_MAC; then
  echo "Ensuring macOS ffmpeg binaries..."
  bin/setup-ffmpeg --mac
fi
if $BUILD_LINUX; then
  echo "Ensuring Linux ffmpeg binaries..."
  bin/setup-ffmpeg --linux
fi

# ── 5. Build macOS package (native, no Docker needed) ──────────────
if $BUILD_MAC; then
  echo ""
  echo "Building macOS app v$CURRENT_VERSION..."
  npx electron-builder --mac --publish never
fi

# ── 6. Build Linux package ─────────────────────────────────────────
if $BUILD_LINUX; then
  HOST_OS="$(uname -s)"

  if [ "$HOST_OS" = "Linux" ]; then
    # Native Linux build — no Docker needed
    echo ""
    echo "Building Linux app v$CURRENT_VERSION..."
    npx electron-builder --linux --x64 --publish never
  else
    # Cross-compile via Docker (macOS → Linux x64)
    # Native modules (better-sqlite3) must be compiled inside a Linux
    # x64 container so the .node binary has the correct ELF architecture.
    echo ""
    echo "Cross-compiling Linux app v$CURRENT_VERSION via Docker..."
    echo "(Native modules require a Linux x64 environment)"

    # ── Docker environment setup ──────────────────────────────────
    # Work around credential store issues (common with Colima)
    DOCKER_TMPCONFIG=$(mktemp -d)
    echo '{}' > "$DOCKER_TMPCONFIG/config.json"
    export DOCKER_CONFIG="$DOCKER_TMPCONFIG"

    # Auto-detect Docker socket
    for sock in \
      "$HOME/.colima/default/docker.sock" \
      "/var/run/docker.sock" \
      "$HOME/.docker/run/docker.sock" \
      "$HOME/.orbstack/run/docker.sock"; do
      if [ -S "$sock" ]; then
        export DOCKER_HOST="unix://$sock"
        break
      fi
    done

    if ! docker info >/dev/null 2>&1; then
      echo "Error: Docker is not running. Start Colima/Docker Desktop/OrbStack and retry."
      rm -rf "$DOCKER_TMPCONFIG"
      exit 1
    fi

    echo "Using Docker: ${DOCKER_HOST:-default socket}"
    echo "This may be slow on ARM hosts due to QEMU x86_64 emulation."
    echo ""

    docker run --rm \
      --platform linux/amd64 \
      --name "caramba-linux-build-$$" \
      -v "${PWD}:/host-project:ro" \
      -v "${PWD}/dist:/host-project-dist" \
      -w /build \
      electronuserland/builder:20 \
      /bin/bash -c '
        set -euo pipefail

        echo "==> Copying project files..."
        cp /host-project/package.json /host-project/package-lock.json ./
        cp -r /host-project/electron ./
        cp -r /host-project/dist-react ./
        cp -r /host-project/storage ./
        cp -r /host-project/vendor ./
        [ -d /host-project/public ] && cp -r /host-project/public ./

        echo "==> Installing dependencies (native modules compile for Linux x64)..."
        npm ci

        echo "==> Building AppImage with electron-builder..."
        npx electron-builder --linux AppImage --x64 --publish never

        echo "==> Copying artifacts to host..."
        cp -v dist/*.AppImage /host-project-dist/ 2>/dev/null || true

        echo ""
        echo "==> Linux build complete!"
      '

    rm -rf "$DOCKER_TMPCONFIG"
  fi
fi

# ── 7. Summary ─────────────────────────────────────────────────────
echo ""
echo "Build complete: v$CURRENT_VERSION"
ls -lh dist/*.dmg 2>/dev/null || true
ls -lh dist/*.AppImage 2>/dev/null || true
ls -lh dist/*.deb 2>/dev/null || true

# ── 8. Publish to GitHub Releases ──────────────────────────────────
if $PUBLISH; then
  bin/publish

  echo ""
  echo "Cleaning dist/..."
  rm -rf dist
fi
