#!/usr/bin/env bash
#
# Download static ffmpeg + ffprobe binaries for bundling into the Electron app.
# Source: https://evermeet.cx/ffmpeg/ (macOS arm64/x86_64 universal static builds)
#
# Usage: bin/setup-ffmpeg
#
set -euo pipefail

cd "$(dirname "$0")/.."

VENDOR_DIR="vendor/ffmpeg"

# Check if already present
if [ -x "$VENDOR_DIR/ffmpeg" ] && [ -x "$VENDOR_DIR/ffprobe" ]; then
  echo "ffmpeg binaries already present:"
  "$VENDOR_DIR/ffmpeg" -version | head -1
  "$VENDOR_DIR/ffprobe" -version | head -1
  exit 0
fi

# Require 7z for extraction
if ! command -v 7z &>/dev/null; then
  echo "Installing p7zip..."
  brew install p7zip
fi

mkdir -p "$VENDOR_DIR"

echo "Downloading static ffmpeg..."
curl -sL "https://evermeet.cx/ffmpeg/getrelease/ffmpeg/7z" -o /tmp/ffmpeg.7z

echo "Downloading static ffprobe..."
curl -sL "https://evermeet.cx/ffmpeg/getrelease/ffprobe/7z" -o /tmp/ffprobe.7z

echo "Extracting..."
7z e /tmp/ffmpeg.7z -o"$VENDOR_DIR" -y >/dev/null
7z e /tmp/ffprobe.7z -o"$VENDOR_DIR" -y >/dev/null

chmod +x "$VENDOR_DIR/ffmpeg" "$VENDOR_DIR/ffprobe"

# Clean up
rm -f /tmp/ffmpeg.7z /tmp/ffprobe.7z

echo ""
echo "Done:"
"$VENDOR_DIR/ffmpeg" -version | head -1
"$VENDOR_DIR/ffprobe" -version | head -1
ls -lh "$VENDOR_DIR/"
