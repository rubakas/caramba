#!/usr/bin/env bash
#
# Download static ffmpeg + ffprobe binaries for bundling into the Electron app.
#
# macOS:  https://evermeet.cx/ffmpeg/ (arm64/x86_64 universal static builds)
# Linux:  https://johnvansickle.com/ffmpeg/ (amd64 static builds)
#
# Usage: bin/setup-ffmpeg          # current platform
#        bin/setup-ffmpeg --linux   # force Linux (for cross-compile on macOS)
#        bin/setup-ffmpeg --mac     # force macOS
#        bin/setup-ffmpeg --all     # both platforms
#
set -euo pipefail

cd "$(dirname "$0")/.."

setup_mac() {
  local dir="vendor/ffmpeg"

  if [ -x "$dir/ffmpeg" ] && [ -x "$dir/ffprobe" ]; then
    echo "macOS ffmpeg already present:"
    "$dir/ffmpeg" -version | head -1
    return 0
  fi

  # Require 7z for extraction
  if ! command -v 7z &>/dev/null; then
    echo "Installing p7zip..."
    brew install p7zip
  fi

  mkdir -p "$dir"

  echo "Downloading static ffmpeg (macOS)..."
  curl -sL "https://evermeet.cx/ffmpeg/getrelease/ffmpeg/7z" -o /tmp/ffmpeg.7z

  echo "Downloading static ffprobe (macOS)..."
  curl -sL "https://evermeet.cx/ffmpeg/getrelease/ffprobe/7z" -o /tmp/ffprobe.7z

  echo "Extracting..."
  7z e /tmp/ffmpeg.7z -o"$dir" -y >/dev/null
  7z e /tmp/ffprobe.7z -o"$dir" -y >/dev/null

  chmod +x "$dir/ffmpeg" "$dir/ffprobe"
  rm -f /tmp/ffmpeg.7z /tmp/ffprobe.7z

  echo "Done (macOS):"
  "$dir/ffmpeg" -version | head -1
  ls -lh "$dir/"
}

setup_linux() {
  local dir="vendor/ffmpeg-linux"

  if [ -x "$dir/ffmpeg" ] && [ -x "$dir/ffprobe" ]; then
    echo "Linux ffmpeg already present:"
    echo "  $(ls -lh "$dir/ffmpeg" | awk '{print $5, $9}')"
    return 0
  fi

  mkdir -p "$dir"

  echo "Downloading static ffmpeg (Linux amd64)..."
  curl -sL "https://johnvansickle.com/ffmpeg/releases/ffmpeg-release-amd64-static.tar.xz" -o /tmp/ffmpeg-linux.tar.xz

  echo "Extracting..."
  tar -xf /tmp/ffmpeg-linux.tar.xz -C /tmp/

  cp /tmp/ffmpeg-*-static/ffmpeg /tmp/ffmpeg-*-static/ffprobe "$dir/"
  chmod +x "$dir/ffmpeg" "$dir/ffprobe"

  # Clean up
  rm -rf /tmp/ffmpeg-linux.tar.xz /tmp/ffmpeg-*-static

  echo "Done (Linux x64):"
  ls -lh "$dir/"
}

# Parse args
TARGET="${1:-auto}"

case "$TARGET" in
  --all)
    setup_mac
    echo ""
    setup_linux
    ;;
  --linux)
    setup_linux
    ;;
  --mac)
    setup_mac
    ;;
  auto|"")
    case "$(uname -s)" in
      Darwin) setup_mac ;;
      Linux)  setup_linux ;;
      *)      echo "Unknown platform: $(uname -s)"; exit 1 ;;
    esac
    ;;
  *)
    echo "Usage: bin/setup-ffmpeg [--mac|--linux|--all]"
    exit 1
    ;;
esac
