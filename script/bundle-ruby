#!/usr/bin/env bash
#
# Assembles a portable Ruby runtime + vendored gems + Rails app
# into build/bundle/ for inclusion in the Electron .app.
#
# Usage: script/bundle-ruby
#
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

RUBY_PREFIX="$(ruby -e "puts RbConfig::CONFIG['prefix']")"
RUBY_VER="$(ruby -e "puts RUBY_VERSION")"
RUBY_ARCH="$(ruby -e "puts RbConfig::CONFIG['arch']")"
LIBRUBY="libruby.${RUBY_VER%.*}.dylib"
BUNDLE="build/bundle"

BREW_DYLIBS=(
  /opt/homebrew/opt/gmp/lib/libgmp.10.dylib
  /opt/homebrew/opt/openssl@3/lib/libcrypto.3.dylib
  /opt/homebrew/opt/openssl@3/lib/libssl.3.dylib
  /opt/homebrew/opt/libyaml/lib/libyaml-0.2.dylib
)

echo "Ruby $RUBY_VER ($RUBY_ARCH)"
echo "Output: $BUNDLE"
echo ""

rm -rf "$BUNDLE"
mkdir -p "$BUNDLE"/{bin,lib/ruby,dylib}

# ── 1. Ruby binary + libruby ─────────────────────────────────────────
echo "[1/7] Ruby binary + libruby..."
cp "$RUBY_PREFIX/bin/ruby" "$BUNDLE/bin/ruby"
cp "$RUBY_PREFIX/lib/$LIBRUBY" "$BUNDLE/lib/$LIBRUBY"

# ── 2. Homebrew dylibs ───────────────────────────────────────────────
echo "[2/7] Homebrew dylibs..."
for dylib in "${BREW_DYLIBS[@]}"; do
  [ -f "$dylib" ] && cp "$dylib" "$BUNDLE/dylib/"
done

# ── 3. Ruby stdlib ───────────────────────────────────────────────────
echo "[3/7] Ruby stdlib..."
cp -R "$RUBY_PREFIX/lib/ruby/$RUBY_VER" "$BUNDLE/lib/ruby/$RUBY_VER"

# ── 4. Default gems (bundler, etc.) ─────────────────────────────────
echo "[4/7] Default gems..."
GEMS_DIR="$RUBY_PREFIX/lib/ruby/gems/$RUBY_VER"
BUNDLE_GEMS="$BUNDLE/lib/ruby/gems/$RUBY_VER"
mkdir -p "$BUNDLE_GEMS/specifications/default" "$BUNDLE_GEMS/gems"

# Copy all default gem specs
cp "$GEMS_DIR/specifications/default/"*.gemspec "$BUNDLE_GEMS/specifications/default/"

# Copy bundler gem (needed for bin/rails to boot)
cp -R "$GEMS_DIR/gems/bundler-"* "$BUNDLE_GEMS/gems/" 2>/dev/null || true

# ── 5. Vendor gems ──────────────────────────────────────────────────
echo "[5/7] Vendoring gems..."
bundle config set --local path vendor/bundle
bundle config set --local without 'development:test'
bundle install --quiet 2>&1
cp -R vendor/bundle "$BUNDLE/vendor_bundle"
bundle config unset --local path
bundle config unset --local without

# ── 6. Fix ALL dylib load paths ─────────────────────────────────────
echo "[6/7] Fixing dylib load paths..."

# ruby binary
install_name_tool -change "$RUBY_PREFIX/lib/$LIBRUBY" "@executable_path/../lib/$LIBRUBY" "$BUNDLE/bin/ruby"
install_name_tool -change /opt/homebrew/opt/gmp/lib/libgmp.10.dylib "@executable_path/../dylib/libgmp.10.dylib" "$BUNDLE/bin/ruby"

# libruby install name + deps
install_name_tool -id "@rpath/$LIBRUBY" "$BUNDLE/lib/$LIBRUBY"
install_name_tool -change /opt/homebrew/opt/gmp/lib/libgmp.10.dylib "@loader_path/../dylib/libgmp.10.dylib" "$BUNDLE/lib/$LIBRUBY"

# libssl depends on libcrypto
install_name_tool -change /opt/homebrew/opt/openssl@3/lib/libcrypto.3.dylib "@loader_path/libcrypto.3.dylib" "$BUNDLE/dylib/libssl.3.dylib" 2>/dev/null || true

# Fix every .bundle native extension (stdlib + vendored gems)
find "$BUNDLE/lib/ruby" "$BUNDLE/vendor_bundle" -name "*.bundle" 2>/dev/null | while read -r ext; do
  install_name_tool -change "$RUBY_PREFIX/lib/$LIBRUBY" "@executable_path/../lib/$LIBRUBY" "$ext" 2>/dev/null || true
  for dylib in "${BREW_DYLIBS[@]}"; do
    name="$(basename "$dylib")"
    install_name_tool -change "$dylib" "@executable_path/../dylib/$name" "$ext" 2>/dev/null || true
  done
done

# ── 7. Rails app ─────────────────────────────────────────────────────
echo "[7/7] Rails app..."
RAILS="$BUNDLE/rails"
mkdir -p "$RAILS"

for dir in app bin config db lib public; do
  [ -d "$dir" ] && cp -R "$dir" "$RAILS/$dir"
done
for f in config.ru Gemfile Gemfile.lock Rakefile; do
  [ -f "$f" ] && cp "$f" "$RAILS/$f"
done

mkdir -p "$RAILS/.bundle"
cat > "$RAILS/.bundle/config" <<'EOF'
---
BUNDLE_PATH: "../vendor_bundle"
BUNDLE_WITHOUT: "development:test"
BUNDLE_DEPLOYMENT: "true"
EOF

mkdir -p "$RAILS/log" "$RAILS/tmp/pids" "$RAILS/tmp/cache" "$RAILS/storage"
rm -rf "$RAILS/vendor/bundle"

# Copy database if it exists (so the app starts with data)
[ -f "storage/development.sqlite3" ] && cp "storage/development.sqlite3" "$RAILS/storage/development.sqlite3"

# ── Done ─────────────────────────────────────────────────────────────
echo ""
echo "Done! $(du -sh "$BUNDLE" | awk '{print $1}')"
du -sh "$BUNDLE/bin" "$BUNDLE/lib" "$BUNDLE/dylib" "$BUNDLE/vendor_bundle" "$BUNDLE/rails" 2>/dev/null
